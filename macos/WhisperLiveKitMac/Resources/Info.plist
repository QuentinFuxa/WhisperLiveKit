<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>WhisperLiveKit</string>
    <key>CFBundleIdentifier</key>
    <string>org.whisperlivekit.mac</string>
    <key>CFBundleName</key>
    <string>WhisperLiveKitMac</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © WhisperLiveKit contributors</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>WhisperLiveKit connects to the transcription server you configure.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>WhisperLiveKit records microphone audio and streams it to your transcription server.</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoadsInWebContent</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
