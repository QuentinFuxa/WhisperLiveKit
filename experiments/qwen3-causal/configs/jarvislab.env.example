# Copy to .env or export manually on the H100 machine.
MODEL=Qwen/Qwen3-ASR-0.6B
PORT=8000
GPU_MEMORY_UTILIZATION=0.85

# Training defaults
MODEL_PATH=Qwen/Qwen3-ASR-0.6B
TRAIN_FILE=data/public_realtime/train.jsonl
EVAL_FILE=data/public_realtime/eval.jsonl
OUTPUT_DIR=runs/qwen3-asr-0.6b-native-realtime
BATCH_SIZE=16
GRAD_ACC=4
LR=2e-5
EPOCHS=1
SAVE_STEPS=200
NUM_WORKERS=4

# Native realtime smoke defaults
REALTIME_SMOKE_OUTPUT_DIR=runs/realtime_smoke
REALTIME_SMOKE_STEPS=100

# Multi-GPU, when applicable.
# CUDA_VISIBLE_DEVICES=0,1
# NPROC_PER_NODE=2
